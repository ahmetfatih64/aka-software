---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import MarkdownContent from '../components/MarkdownContent.astro';

import { getEntry } from 'astro:content';
const page = await getEntry('pages', 'hakkimizda');
const data = page?.data || { title: "Hakkımızda" };
const Content = page ? (await page.render()).Content : null;
---
<BaseLayout title={data.title} seoTitle={data.seoTitle} seoDescription={data.seoDescription}>
  <PageHeader title={data.title} description={data.description} />

  <Section>
    <div class="max-w-3xl mx-auto">
      {Content ? (
        <MarkdownContent>
          <Content />
        </MarkdownContent>
      ) : (
        <MarkdownContent>
          <h2>Misyonumuz</h2>
          <p>Yenilikçi teknolojilerle işletmelerin rekabet gücünü artırmak ve dijital dönüşümlerine öncülük etmek.</p>

          <h2>Kurucumuz</h2>
          <p><strong>Ahmet Fatih Kahya</strong> tarafından kurulan <strong>AKA Software</strong>, modern yazılım ekosistemi ve yapay zeka alanlarında derin bir uzmanlığa sahiptir.</p>

          <h2>Neden Bizi Seçmelisiniz?</h2>
          <ul>
            <li><strong>Teknoloji Odaklılık:</strong> En güncel ve rüştünü ispatlamış teknoloji yığınlarını kullanıyoruz.</li>
            <li><strong>Şeffaflık:</strong> Süreçlerimizin her adımında tamamen şeffaf ilerliyoruz.</li>
            <li><strong>Kalite ve Performans:</strong> Yazdığımız kodun kalitesi ve kurduğumuz sistemlerin yüksek performansı önceliğimizdir.</li>
          </ul>
        </MarkdownContent>
      )}
    </div>
  </Section>
</BaseLayout>
