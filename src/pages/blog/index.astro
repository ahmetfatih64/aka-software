---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import PostCard from '../../components/PostCard.astro';

import { getCollection, getEntry } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// Sort by date mostly recent
const sortedPosts = posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const pageData = await getEntry('pages', 'blog') || { 
  data: { 
    title: "Blog", 
    description: "Yazılım geliştirme, yapay zeka ve teknoloji dünyasından son haberler ve makaleler.",
    seoTitle: "Blog | AKA Software",
    seoDescription: "Yapay zeka ve modern yazılım teknolojileri üzerine AKA Software blog yazıları."
  }
};
---
<BaseLayout title={pageData.data.title} seoTitle={pageData.data.seoTitle} seoDescription={pageData.data.seoDescription}>
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{pageData.data.title}</h1>
      {pageData.data.description && <p class="text-xl text-gray-600">{pageData.data.description}</p>}
    </div>
  </section>

  <Section>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.length > 0 ? (
        sortedPosts.map(post => (
          <PostCard post={post} />
        ))
      ) : (
        <div class="col-span-full items-center text-center py-12">
          <p class="text-gray-500 text-lg">Henüz bir blog yazısı bulunmuyor.</p>
        </div>
      )}
    </div>
  </Section>
</BaseLayout>
