---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import MarkdownContent from '../components/MarkdownContent.astro';

import { getEntry } from 'astro:content';
const page = await getEntry('legal', 'gizlilik');

const data = page?.data || { title: "Gizlilik Politikası", description: "Bizi yakından tanıyın.", updatedDate: new Date() };
const Content = page ? (await page.render()).Content : null;
---
<BaseLayout title={data.title} description={data.description}>
  <PageHeader title={data.title} />
  <div class="site-container text-center -mt-8 mb-8">
    <p class="text-sm" style="color: rgb(var(--color-fg-faint));">
      Son Güncelleme: {data.updatedDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  </div>

  <Section>
    <div class="max-w-3xl mx-auto">
      {Content ? (
        <MarkdownContent><Content /></MarkdownContent>
      ) : (
        <MarkdownContent>
          <p>Bu politika, AKA Software'in kullanıcılarına ve müşterilerine ait bilgileri nasıl topladığını, kullandığını ve koruduğunu açıklar.</p>
          <h2>Bilgilerin Toplanması</h2>
          <p>Web sitemiz üzerinden doldurduğunuz formlar aracılığıyla isim, iletişim bilgileri ve projeyle ilgili detayları topluyoruz.</p>
          <h2>Bilgilerin Kullanımı</h2>
          <p>Topladığımız bilgileri sadece size hizmet sunmak, teklif vermek ve süreç hakkında bilgilendirmek amacıyla kullanıyoruz. Üçüncü taraflarla paylaşmıyoruz.</p>
        </MarkdownContent>
      )}
    </div>
  </Section>
</BaseLayout>
