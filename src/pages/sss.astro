---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import FAQList from '../components/FAQ.astro';

import { getEntry } from 'astro:content';
const page = await getEntry('pages', 'sss');
const data = page?.data || { title: "Sıkça Sorulan Sorular" };

const faqItems = [
  {
    q: "Astro nedir ve neden kurumsal web sitemiz için seçtiniz?",
    a: "Astro, modern bir web çerçevesidir. En büyük avantajı, varsayılan olarak JavaScript'i sıfırlayarak (Zero JS) HTML üretmesidir. Bu sayede inanılmaz hızlı yüklenen, SEO dostu ve erişilebilir web siteleri kurmamızı sağlar."
  },
  {
    q: "Proje geliştirme süreciniz nasıl işliyor?",
    a: "Öncelikle 'Keşif Görüşmesi' ile ihtiyaçlarınızı belirliyoruz. Ardından detaylı bir teklif sunuyor, onayınızla birlikle teknik planlamayı yapıp geliştirmeye başlıyoruz. Düzenli geri bildirimlerle süreci yönetiyoruz."
  },
  {
    q: "Yapay zeka modellerini nasıl entegre ediyorsunuz?",
    a: "İhtiyacınıza göre OpenAI, Anthropic gibi bulut tabanlı API API'larını kullanıyor veya verilerin gizliliğine göre açık kaynaklı modelleri (Llama vb.) kendi sunucularınıza (on-premise) kuruyoruz."
  },
  {
    q: "Web sitemizin içeriklerini nasıl güncelleyebiliriz?",
    a: "Projemiz, Markdown (Content Collections) tabanlıdır. İçeriklerinizi basit `.md` uzantılı dosyaları güncelleyerek anında değiştirebilirsiniz. Herhangi bir veritabanı veya karmaşık CMS kurulumuna ihtiyaç duymaz."
  }
]
---
<BaseLayout title={data.title} seoTitle={data.seoTitle} seoDescription={data.seoDescription}>
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="container mx-auto px-4 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">{data.title}</h1>
      {data.description && <p class="text-xl text-gray-600">{data.description}</p>}
    </div>
  </section>

  <Section>
    <FAQList items={faqItems} />
  </Section>
</BaseLayout>
