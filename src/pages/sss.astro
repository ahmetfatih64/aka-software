---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import FAQList from '../components/FAQ.astro';

import { getEntry } from 'astro:content';
const page = await getEntry('pages', 'sss');
const data = page?.data || { title: "Sıkça Sorulan Sorular" };

const faqItems = [
  {
    q: "Astro nedir ve neden kurumsal web sitemiz için seçtiniz?",
    a: "Astro, modern bir web çerçevesidir. En büyük avantajı, varsayılan olarak JavaScript'i sıfırlayarak (Zero JS) HTML üretmesidir. Bu sayede inanılmaz hızlı yüklenen, SEO dostu ve erişilebilir web siteleri kurmamızı sağlar."
  },
  {
    q: "Proje geliştirme süreciniz nasıl işliyor?",
    a: "Öncelikle 'Keşif Görüşmesi' ile ihtiyaçlarınızı belirliyoruz. Ardından detaylı bir teklif sunuyor, onayınızla birlikte teknik planlamayı yapıp geliştirmeye başlıyoruz. Düzenli geri bildirimlerle süreci yönetiyoruz."
  },
  {
    q: "Yapay zeka modellerini nasıl entegre ediyorsunuz?",
    a: "İhtiyacınıza göre OpenAI, Anthropic gibi bulut tabanlı API'ları kullanıyor veya verilerin gizliliğine göre açık kaynaklı modelleri kendi sunucularınıza kuruyoruz."
  },
  {
    q: "Web sitemizin içeriklerini nasıl güncelleyebiliriz?",
    a: "Projemiz, Markdown tabanlıdır. İçeriklerinizi basit .md uzantılı dosyaları güncelleyerek anında değiştirebilirsiniz. Herhangi bir veritabanı veya karmaşık CMS kurulumuna ihtiyaç duymaz."
  }
];
---
<BaseLayout title={data.title} seoTitle={data.seoTitle} seoDescription={data.seoDescription}>
  <PageHeader title={data.title} description={data.description} />

  <Section>
    <FAQList items={faqItems} />
  </Section>
</BaseLayout>
