---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sayfa Bulunamadı - 404">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-5 pt-32">
    <div class="text-8xl font-bold mb-4" style="color: rgb(var(--color-border));">404</div>
    <h1 class="text-2xl font-semibold tracking-tight mb-3" style="color: rgb(var(--color-fg));">Aradığınız Sayfa Bulunamadı</h1>
    <p class="text-base mb-8 max-w-md" style="color: rgb(var(--color-fg-muted));">
      Bu sayfa taşınmış, silinmiş veya adresi yanlış girilmiş olabilir.
    </p>
    <a href="/" class="btn-primary">
      Ana Sayfaya Dön
    </a>
  </div>
</BaseLayout>
