---
interface Props {
  title?: string;
  description?: string;
  eyebrow?: string;
  class?: string;
  id?: string;
  bg?: 'default' | 'muted';
}
const { title, description, eyebrow, class: className = '', id, bg = 'default' } = Astro.props;
const bgStyle = bg === 'muted' ? `background: rgb(var(--color-muted) / 0.5);` : '';
---
<section id={id} class={`section-block ${className}`} style={bgStyle}>
  <div class="site-container">
    {(title || description || eyebrow) && (
      <div class="mx-auto mb-12 max-w-2xl text-center">
        {eyebrow && <div class="section-eyebrow">{eyebrow}</div>}
        {title && <h2 class="section-title">{title}</h2>}
        {description && <p class="section-description mx-auto">{description}</p>}
      </div>
    )}
    <slot />
  </div>
</section>
