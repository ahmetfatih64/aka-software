---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, publishDate, tags } = post.data;
---
<a href={`/blog/${post.slug}`} class="group card card-hover flex flex-col">
  <div class="flex-grow flex flex-col">
    <div class="flex gap-2 mb-4 flex-wrap">
      {tags.map((tag: string) => (
        <span class="badge">{tag}</span>
      ))}
    </div>
    <h3 class="text-lg font-semibold mb-2 transition-colors duration-150" style="color: rgb(var(--color-fg));">
      {title}
    </h3>
    <p class="text-sm leading-relaxed mb-4 flex-grow" style="color: rgb(var(--color-fg-muted));">
      {description}
    </p>
    <div class="text-xs font-medium" style="color: rgb(var(--color-fg-faint));">
      <time datetime={publishDate.toISOString()}>
        {publishDate.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </div>
  </div>
</a>
