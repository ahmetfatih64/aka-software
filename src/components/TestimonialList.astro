---
interface Testimonial {
  quote: string;
  author: string;
  role: string;
}
interface Props {
  testimonials: Testimonial[];
}
const { testimonials } = Astro.props;
---
<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
  {testimonials.map(t => (
    <figure class="card card-hover flex h-full flex-col justify-between gap-4">
      <div>
        <svg class="mb-4 h-6 w-6 opacity-30" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="color: rgb(var(--color-accent));">
          <path d="M9.5 5.25C6.6 5.25 4.5 7.35 4.5 10.25c0 2.85 2.05 4.7 4.95 4.7.1 0 .25 0 .35-.05-.25 1.55-1.1 2.35-2.35 3.15-.25.15-.3.45-.2.7l.75 1.35c.15.3.5.4.8.25 2.7-1.4 4.2-3.45 4.2-7.05v-8c0-.6-.45-1.05-1.05-1.05h-1.95Zm8 0c-2.9 0-5 2.1-5 5 0 2.85 2.05 4.7 4.95 4.7.1 0 .25 0 .35-.05-.25 1.55-1.1 2.35-2.35 3.15-.25.15-.3.45-.2.7l.75 1.35c.15.3.5.4.8.25 2.7-1.4 4.2-3.45 4.2-7.05v-8c0-.6-.45-1.05-1.05-1.05h-1.95Z" />
        </svg>
        <blockquote class="text-sm leading-relaxed" style="color: rgb(var(--color-fg-muted));">
          "{t.quote}"
        </blockquote>
      </div>
      <figcaption class="mt-4 border-t pt-4" style="border-color: rgb(var(--color-border));">
        <div class="text-sm font-medium" style="color: rgb(var(--color-fg));">{t.author}</div>
        <div class="text-xs" style="color: rgb(var(--color-fg-faint));">{t.role}</div>
      </figcaption>
    </figure>
  ))}
</div>
