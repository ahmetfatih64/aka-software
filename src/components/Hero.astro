---
interface Props {
  title: string;
  description: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}
const { title, description, primaryCtaText, primaryCtaLink, secondaryCtaText, secondaryCtaLink } = Astro.props;
---
<section class="relative pt-24 pb-32 md:pt-36 md:pb-40 overflow-hidden bg-gray-50">
  <div class="container mx-auto px-4 text-center relative z-10">
    <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 tracking-tight leading-tight mb-6 max-w-4xl mx-auto">
      {title}
    </h1>
    <p class="text-xl md:text-2xl text-gray-600 mb-10 max-w-2xl mx-auto">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      {primaryCtaText && primaryCtaLink && (
        <a href={primaryCtaLink} class="bg-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition shadow-lg">
          {primaryCtaText}
        </a>
      )}
      {secondaryCtaText && secondaryCtaLink && (
        <a href={secondaryCtaLink} class="bg-white text-gray-900 border border-gray-200 px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-50 transition shadow">
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
  
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-0 opacity-40 mix-blend-multiply pointer-events-none">
    <div class="absolute -top-[10%] -right-[10%] w-[50%] h-[50%] rounded-full bg-blue-100 blur-[100px]"></div>
    <div class="absolute top-[40%] -left-[10%] w-[40%] h-[40%] rounded-full bg-indigo-100 blur-[80px]"></div>
  </div>
</section>
