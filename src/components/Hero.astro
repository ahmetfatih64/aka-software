---
interface Props {
  title: string;
  description: string;
  primaryCtaText?: string;
  primaryCtaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}
const { title, description, primaryCtaText, primaryCtaLink, secondaryCtaText, secondaryCtaLink } = Astro.props;
---
<section class="relative pt-32 pb-20 md:pt-40 md:pb-28">
  <div class="site-container">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">

      <!-- Left: copy -->
      <div class="max-w-xl space-y-8">
        <div class="section-eyebrow">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          AI destekli yazılım danışmanlığı
        </div>

        <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl md:text-[3.25rem] md:leading-[1.08]" style="color: rgb(var(--color-fg));">
          {title}
        </h1>

        <p class="max-w-lg text-base leading-relaxed md:text-lg" style="color: rgb(var(--color-fg-muted));">
          {description}
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          {primaryCtaText && primaryCtaLink && (
            <a href={primaryCtaLink} class="btn-primary">
              {primaryCtaText}
            </a>
          )}
          {secondaryCtaText && secondaryCtaLink && (
            <a href={secondaryCtaLink} class="btn-secondary">
              {secondaryCtaText}
            </a>
          )}
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap gap-4 text-xs" style="color: rgb(var(--color-fg-faint));">
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-lg bg-emerald-500/10 text-[0.6rem] font-semibold text-emerald-600 dark:text-emerald-400">
              24h
            </span>
            <span>Ortalama ilk dönüş</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-lg text-[0.6rem] font-semibold" style="background: rgb(var(--color-accent) / 0.1); color: rgb(var(--color-accent));">
              NDA
            </span>
            <span>Gizlilik odaklı</span>
          </div>
        </div>
      </div>

      <!-- Right: product panel -->
      <div class="hidden lg:block">
        <div class="rounded-2xl border p-6 space-y-5" style="background: rgb(var(--color-card)); border-color: rgb(var(--color-border)); box-shadow: 0 8px 30px rgba(0,0,0,0.06);">

          <!-- Panel header -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
              <span class="text-xs font-medium" style="color: rgb(var(--color-fg-muted));">Canlı proje metrikleri</span>
            </div>
            <span class="badge">Son 30 gün</span>
          </div>

          <!-- Metrics -->
          <div class="grid grid-cols-3 gap-3">
            <div class="metric-pill">
              <span class="metric-pill-label">MVP süresi</span>
              <span class="metric-pill-value">2-6 hafta</span>
            </div>
            <div class="metric-pill">
              <span class="metric-pill-label">Dönüşüm</span>
              <span class="metric-pill-value text-emerald-600 dark:text-emerald-400">+%18</span>
            </div>
            <div class="metric-pill">
              <span class="metric-pill-label">Memnuniyet</span>
              <span class="metric-pill-value">4.8/5</span>
            </div>
          </div>

          <!-- Mini feature list -->
          <div class="space-y-3 pt-2">
            <div class="flex items-center gap-3 rounded-xl p-3 border" style="border-color: rgb(var(--color-border));">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-xs font-semibold" style="background: rgb(var(--color-accent) / 0.1); color: rgb(var(--color-accent));">
                AI
              </span>
              <div>
                <div class="text-sm font-medium" style="color: rgb(var(--color-fg));">LLM entegrasyon</div>
                <div class="text-xs" style="color: rgb(var(--color-fg-faint));">-%37 yanıt süresi</div>
              </div>
            </div>
            <div class="flex items-center gap-3 rounded-xl p-3 border" style="border-color: rgb(var(--color-border));">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-xs font-semibold bg-emerald-500/10 text-emerald-600 dark:text-emerald-400">
                API
              </span>
              <div>
                <div class="text-sm font-medium" style="color: rgb(var(--color-fg));">Kurumsal mimari</div>
                <div class="text-xs" style="color: rgb(var(--color-fg-faint));">CRM, ERP entegrasyonları</div>
              </div>
            </div>
          </div>

          <!-- Mini testimonial -->
          <div class="rounded-xl p-4" style="background: rgb(var(--color-muted));">
            <p class="text-sm leading-relaxed" style="color: rgb(var(--color-fg-muted));">
              "Teknik detaylarıyla uğraşmadan ürün tarafına odaklanabildik."
            </p>
            <p class="mt-2 text-xs" style="color: rgb(var(--color-fg-faint));">
              Ürün Lideri — gizli müşteri (NDA)
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
