---
import type { CollectionEntry } from 'astro:content';

interface Props {
  study: CollectionEntry<'case-studies'>;
}
const { study } = Astro.props;
const { title, description, industry, services } = study.data;
---
<a href={`/vaka-calismalari/${study.slug}`} class="group card card-hover flex flex-col">
  <div class="text-xs font-medium uppercase tracking-widest mb-2" style="color: rgb(var(--color-accent));">
    {industry}
  </div>
  <h3 class="text-xl font-semibold mb-3 transition-colors duration-150" style="color: rgb(var(--color-fg));">
    {title}
  </h3>
  <p class="text-sm leading-relaxed mb-4 flex-grow" style="color: rgb(var(--color-fg-muted));">
    {description}
  </p>
  <div class="flex flex-wrap gap-2">
    {services.map((service: string) => (
      <span class="badge">{service}</span>
    ))}
  </div>
</a>
