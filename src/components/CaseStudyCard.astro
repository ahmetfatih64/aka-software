---
import type { CollectionEntry } from 'astro:content';

interface Props {
  study: CollectionEntry<'case-studies'>;
}
const { study } = Astro.props;
const { title, description, industry, services } = study.data;
---
<a href={`/vaka-calismalari/${study.slug}`} class="group block bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow duration-300">
  <div class="p-8">
    <div class="text-sm font-bold tracking-widest text-blue-600 uppercase mb-2">{industry}</div>
    <h3 class="text-2xl font-bold text-gray-900 mb-4 group-hover:text-blue-600 transition-colors">{title}</h3>
    <p class="text-gray-600 mb-6">{description}</p>
    <div class="flex flex-wrap gap-2">
      {services.map((service: string) => (
        <span class="text-xs font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full">{service}</span>
      ))}
    </div>
  </div>
</a>
