---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
}
const { 
  title = "Projeleriniz için AI Destekli Çözümler", 
  description = "İşletmenizi bir adım öteye taşımak için uzman ekibimizle tanışın. Ücretsiz keşif görüşmesi ayarlayın.",
  buttonText = "Ücretsiz Keşif Görüşmesi",
  buttonLink = "/iletisim"
} = Astro.props;
---
<section class="py-20 bg-blue-600 text-white text-center">
  <div class="container mx-auto px-4 max-w-4xl">
    <h2 class="text-3xl md:text-5xl font-bold mb-6">{title}</h2>
    <p class="text-xl text-blue-100 mb-10">{description}</p>
    <a href={buttonLink} class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-50 transition shadow-lg">
      {buttonText}
    </a>
  </div>
</section>
