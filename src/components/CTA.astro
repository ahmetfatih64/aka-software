---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
}
const {
  title = "Projeleriniz için AI destekli çözümler",
  description = "İşletmenizi bir adım öteye taşımak için uzman ekibimizle tanışın.",
  buttonText = "Ücretsiz Keşif Görüşmesi",
  buttonLink = "/iletisim"
} = Astro.props;
---
<section class="section-block">
  <div class="site-container">
    <div class="relative overflow-hidden rounded-2xl border px-6 py-12 text-center sm:px-10 md:px-16 md:py-16"
      style="background: rgb(var(--color-accent)); border-color: rgb(var(--color-accent) / 0.3);"
    >
      <div class="relative mx-auto max-w-2xl space-y-6">
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl" style="color: rgb(var(--color-accent-fg));">
          {title}
        </h2>
        <p class="text-sm leading-relaxed md:text-base" style="color: rgb(var(--color-accent-fg) / 0.8);">
          {description}
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={buttonLink} class="btn rounded-xl px-6 py-3 text-sm font-medium shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"
            style="background: rgb(var(--color-accent-fg)); color: rgb(var(--color-accent));"
          >
            {buttonText}
          </a>
        </div>
        <p class="text-xs" style="color: rgb(var(--color-accent-fg) / 0.6);">
          Çoğu projede ilk taslak çözümü <span class="font-semibold">7 iş günü</span> içinde sunuyoruz.
        </p>
      </div>
    </div>
  </div>
</section>
