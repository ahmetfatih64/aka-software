        <li><a href="/kullanim-sartlari" class="hover:text-blue-400">Kullanım Şartları</a></li>
        <li><a href="/sss" class="hover:text-blue-400">Sıkça Sorulan Sorular (SSS)</a></li>
      </ul>
    </div>
    
    <div>
      <h3 class="text-white font-semibold mb-4">İletişim</h3>
      <address class="text-sm not-italic space-y-2 text-gray-400">
        <p>Ahmet Fatih Kahya</p>
        <p><a href="mailto:info@akasoftware.com" class="hover:text-blue-400">info@akasoftware.com</a></p>
      </address>
    </div>
  </div>
  
  <div class="container mx-auto px-4 mt-8 pt-8 border-t border-gray-800 text-sm text-center text-gray-500">
    &copy; {currentYear} AKA Software. Tüm hakları saklıdır.
