# Example Environment File
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to Git!

# Database Credentials
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=secret

# JWT Authentication
# JWT_SECRET=your_super_secret_jwt_key_here

# Third-Party APIs
# OPENAI_API_KEY=sk-.....
# SENDGRID_API_KEY=SG......
